@{
    ViewData["Title"] = "Manager Dashboard";
    var lowStock = ViewBag.LowStock as List<MySuperPOS.Models.Product>;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0 text-gray-800"><i class="bi bi-speedometer2 me-2"></i>Management Dashboard</h1>
                <p class="text-muted">Business performance overview for @DateTime.Now.ToString("dd MMMM yyyy")</p>
            </div>
            <a asp-controller="POS" asp-action="Index" class="btn btn-primary shadow-sm px-4">
                <i class="bi bi-calculator me-2"></i> Open Sales Terminal
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 border-start border-primary border-5 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="row align-items-center">
                        <div class="col">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Today's Revenue</div>
                            <div class="h3 mb-0 font-weight-bold">R @ViewBag.DailyTotal.ToString("N2")</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-cash-coin fs-1 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="card border-0 border-start border-success border-5 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="row align-items-center">
                        <div class="col">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Transactions</div>
                            <div class="h3 mb-0 font-weight-bold">@ViewBag.TransactionCount</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-receipt-cutoff fs-1 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="card border-0 border-start border-warning border-5 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="row align-items-center">
                        <div class="col">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Low Stock Alerts</div>
                            <div class="h3 mb-0 font-weight-bold">@lowStock?.Count</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-exclamation-diamond fs-1 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 font-weight-bold text-primary">
                        <i class="bi bi-graph-up me-2"></i>Revenue Trend (Last 7 Days)
                    </h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px; position: relative;">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 font-weight-bold text-danger"><i class="bi bi-bell-fill me-2"></i>Critical Stock Items</h5>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-secondary">Inventory Manager</a>
                </div>
                <div class="card-body">
                    @if (lowStock != null && lowStock.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Product</th>
                                        <th>Category</th>
                                        <th>Stock Level</th>
                                        <th>Status</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in lowStock)
                                    {
                                        <tr>
                                            <td class="fw-bold">@item.Name</td>
                                            <td><span class="badge bg-light text-dark border">@item.Category</span></td>
                                            <td class="fw-bold @(item.StockQuantity == 0 ? "text-danger" : "text-warning")">
                                                @item.StockQuantity
                                            </td>
                                            <td>
                                                @if (item.StockQuantity == 0)
                                                {
                                                    <span class="badge bg-danger">Out of Stock</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">Low Stock</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm">
                                                    <i class="bi bi-box-arrow-in-down"></i> Restock
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle-fill text-success fs-1"></i>
                            <p class="mt-2 text-muted">All inventory levels are currently sufficient.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        // Setup Chart.js
        const ctx = document.getElementById('salesChart').getContext('2d');
        
        // Data passed from ViewBag
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels));
        const dataValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartData));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Daily Revenue (R)',
                    data: dataValues,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.05)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.3,
                    pointBackgroundColor: '#0d6efd',
                    pointRadius: 4,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) { return 'R ' + value; }
                        }
                    }
                }
            }
        });
    </script>

    <style>
        .border-5 { border-width: 5px !important; }
        .text-xs { font-size: .75rem; font-weight: 700; color: #858796; }
        .card { transition: transform 0.2s; }
        .card:hover { transform: translateY(-3px); }
    </style>
}