@model IEnumerable<MySuperPOS.Models.Product>

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-box-seam me-2"></i>Product Inventory</h2>
            <p class="text-muted small">Manage stock levels, prices, and generate barcodes.</p>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Add New Product
            </a>
            <a asp-controller="Products" asp-action="PrintBarcodes" class="btn btn-dark">
                <i class="bi bi-printer me-1"></i> Print All Labels
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <h6 class="fw-bold mb-1">Bulk Inventory Update</h6>
                            <p class="text-muted small mb-0">Upload a CSV file to add new items or update existing stock levels.</p>
                        </div>
                        <div class="col-md-8">
                            <<form asp-controller="Products" asp-action="UploadCSV" method="post" enctype="multipart/form-data" class="row g-2 justify-content-md-end">
                                <div class="col-auto">
                                    <input type="file" name="file" class="form-control form-control-sm shadow-none" accept=".csv" required />
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-sm btn-dark px-4">
                                        <i class="bi bi-upload me-1"></i> Upload CSV
                                    </button>
                                </div>
                            </form>
                            <div class="text-md-end mt-1">
                                <span class="badge bg-white text-muted border fw-normal" style="font-size: 0.7rem;">Required Headers: Name, Category, Price, StockQuantity</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-white">
                            <tr class="text-muted small text-uppercase">
                                <th class="ps-4">Product Details</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Current Stock</th>
                                <th style="width: 220px;">Quick Restock</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold text-dark">@item.Name</div>
                                            <div class="small text-muted text-truncate" style="max-width: 200px;">@item.Description</div>
                                        </td>
                                        <td>
                                            <span class="badge bg-soft-primary text-primary px-2 py-1">@item.Category</span>
                                        </td>
                                        <td class="fw-bold">R @item.Price.ToString("F2")</td>
                                        <td>
                                            @if (item.StockQuantity <= 5)
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>@item.StockQuantity</span>
                                            }
                                            else if (item.StockQuantity <= 15)
                                            {
                                                <span class="badge bg-warning text-dark">@item.StockQuantity</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">@item.StockQuantity</span>
                                            }
                                        </td>
                                        <td>
                                            <form asp-action="Restock" method="post" class="d-flex gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="number" name="addedQuantity" class="form-control form-control-sm shadow-none border-primary-subtle" placeholder="+ Qty" min="1" required />
                                                <button type="submit" class="btn btn-sm btn-primary border-0" title="Add Stock">
                                                    <i class="bi bi-plus-circle-fill"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group shadow-sm border rounded">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-white text-info" title="View"><i class="bi bi-eye"></i></a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-white text-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                        No products found in the database.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.1); }
    .btn-white { background-color: #fff; border: none; }
    .btn-white:hover { background-color: #f8f9fa; }
    .table thead th { border-top: none; border-bottom: 1px solid #eee; padding-top: 15px; padding-bottom: 15px; }
    .form-control-sm:focus { border-color: #0d6efd; box-shadow: none; }
    /* Removes the number arrows for a cleaner look */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
</style>