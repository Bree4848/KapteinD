@model IEnumerable<MySuperPOS.Models.Product>

@{
    ViewData["Title"] = "Inventory Control";
}

<div class="container-fluid py-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark">
                <i class="bi bi-box-seam-fill text-primary me-2"></i>Inventory Management
            </h2>
            <p class="text-muted small mb-0">Manage stock levels, barcodes, and bulk imports.</p>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Add Product
            </a>
            <a asp-action="PrintBarcodes" class="btn btn-dark">
                <i class="bi bi-printer me-1"></i> Print Labels
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-lg-4 mb-3 mb-lg-0">
                    <h6 class="fw-bold mb-1">Bulk Inventory Update</h6>
                    <p class="text-muted small mb-0">Import products or update stock using a CSV file.</p>
                </div>
                <div class="col-lg-8">
                    <form asp-action="UploadCSV" method="post" enctype="multipart/form-data" class="row g-2 justify-content-lg-end">
                        <div class="col-auto">
                            <input type="file" name="file" class="form-control form-control-sm shadow-none" accept=".csv" required />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-sm btn-dark px-4">
                                <i class="bi bi-cloud-upload me-1"></i> Upload CSV
                            </button>
                        </div>
                    </form>
                    <div class="text-lg-end mt-1">
                        <small class="text-muted" style="font-size: 0.75rem;">Headers: Name, Category, Price, StockQuantity, Description</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-white">
                    <tr class="text-muted small text-uppercase">
                        <th class="ps-4 py-3">Product Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th style="width: 200px;">Quick Restock</th>
                        <th class="text-end pe-4">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded p-2 me-3">
                                        <i class="bi bi-tag text-secondary"></i>
                                    </div>
                                    <div>
                                        <span class="fw-bold d-block text-dark">@item.Name</span>
                                        <span class="text-muted small">ID: @item.Id.ToString().PadLeft(8, '0')</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-soft-info text-info rounded-pill px-3">@item.Category</span>
                            </td>
                            <td class="fw-bold text-dark">R @item.Price.ToString("F2")</td>
                            <td>
                                @if (item.StockQuantity <= 5)
                                {
                                    <span class="badge bg-danger">Critical: @item.StockQuantity</span>
                                }
                                else if (item.StockQuantity <= 15)
                                {
                                    <span class="badge bg-warning text-dark">Low: @item.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.StockQuantity</span>
                                }
                            </td>
                            <td>
                                <form asp-action="Restock" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="number" name="addedQuantity" class="form-control form-control-sm shadow-none border-primary-subtle" placeholder="+ Qty" min="1" required />
                                    <button type="submit" class="btn btn-sm btn-primary border-0" title="Add Stock">
                                        <i class="bi bi-plus-circle"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm shadow-sm border rounded">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white text-primary" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white text-info" title="View Details"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-white text-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



<style>
    /* Soft colored badges */
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.15); }
    
    /* Buttons and controls */
    .btn-white { background: #fff; border: none; }
    .btn-white:hover { background: #f8f9fa; }
    
    /* Table Styling */
    .table thead th { border-bottom: 2px solid #f8f9fa; }
    .table tbody tr { transition: background 0.2s; }
    
    /* Remove default arrows from number input for a cleaner look */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
      -webkit-appearance: none; 
      margin: 0; 
    }
</style>